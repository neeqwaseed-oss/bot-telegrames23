# Environment
ENV=production
DEBUG=false
SECRET_KEY=change-this-to-a-secure-key

# API Gateway
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Telegram Bot
BOT_TOKEN=your-telegram-bot-token
WEBHOOK_URL=https://your-domain.com
WEBHOOK_SECRET=your-secure-webhook-secret

# Database
DATABASE_URL=postgresql+asyncpg://tcgis_user:tcgis_password@postgres:5432/tcgis
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_POOL_SIZE=50

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=groups

# Scraping
PROXY_POOL=
USER_AGENT_ROTATION=true
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_BOT_TOKEN=

# Monitoring
SENTRY_DSN=
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ML Models
LANGUAGE_MODEL_PATH=/models/lid.176.bin
CATEGORY_MODEL_PATH=/models/category_classifier
SPAM_MODEL_PATH=/models/spam_detector
